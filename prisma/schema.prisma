  APPROVAL_DECISION
  REJECTION
  REVISION_REQUEST
  DEADLINE
  PAYROLL_READY
  AI_REPORT
  EMPLOYEE_APPROVAL_REQUEST
  SCRUM_TASK_COMPLETED
  SCRUM_ENTRY_LOCKED
  SCRUM_BLOCKER_ADDED
  DEPARTMENT_CHANGED
  ROLE_CHANGED
  ANNOUNCEMENT
  PASSWORD_CHANGED
  RECURRING_ISSUE_DETECTED

  @@map("notification_type")
}

enum NotificationChannel {
  IN_APP
  EMAIL

  @@map("notification_channel")
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED

  @@map("notification_status")
}

/// Groups notifications for the Notification Center's category tabs. Some values
/// (SCHEDULE, SECURITY, LEAVE, PERFORMANCE) have no publishing module yet — they
/// exist so the UI/architecture is ready without a redesign once those modules ship.
enum NotificationCategory {
  DAILY_SCRUM
  TIMESHEETS
  PAYROLL
  ACCOUNT
  SYSTEM
  SCHEDULE
  SECURITY
  LEAVE
  PERFORMANCE

  @@map("notification_category")
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH

  @@map("notification_priority")
}

model Notification {
  id             String               @id @default(uuid()) @db.Uuid
  tenantId       String               @map("tenant_id") @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  senderId       String?              @map("sender_id") @db.Uuid
  type           NotificationType
  category       NotificationCategory
  priority       NotificationPriority @default(NORMAL)
  channel        NotificationChannel
  status         NotificationStatus   @default(PENDING)
  title          String
  message        String
  actionUrl      String?              @map("action_url")
  actionLabel    String?              @map("action_label")
  metadata       Json                 @default("{}")
  isRead         Boolean              @default(false) @map("is_read")
  readAt         DateTime?            @map("read_at") @db.Timestamptz
  isArchived     Boolean              @default(false) @map("is_archived")
  createdBy      String?              @map("created_by") @db.Uuid
  updatedBy      String?              @map("updated_by") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?            @map("deleted_at") @db.Timestamptz
  version        Int                  @default(0)

  user   User  @relation(fields: [userId], references: [id])
  sender User? @relation("NotificationSender", fields: [senderId], references: [id])

  @@index([tenantId, userId, isRead, createdAt(sort: Desc)])
  @@index([tenantId, userId, category])
  @@index([tenantId, organizationId])
  @@map("notifications")
}

// ─── AI Jobs & Results — Phase 4 §17 ─────────────────────────────────────────

enum AiFeature {
  DAILY_SUMMARY
  WEEKLY_SUMMARY
  TIMESHEET_SUMMARY
  PAYROLL_VALIDATION
  KPI_ANALYSIS
  BLOCKER_DETECTION
  PRODUCTIVITY_INSIGHT
  SUPERVISOR_ADVISORY
  FINANCE_REPORT

  @@map("ai_feature")
}

enum AiProvider {
  OPENAI
  ANTHROPIC
  LOCAL

  @@map("ai_provider")
}

enum AiJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED

  @@map("ai_job_status")
}

model AiJob {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  feature     AiFeature
  provider    AiProvider  @default(ANTHROPIC)
  model       String      @default("claude-haiku-4-5-20251001")
  status      AiJobStatus @default(QUEUED)
  subjectId   String?     @map("subject_id") @db.Uuid
  subjectType String?     @map("subject_type")
  totalTokens Int?        @map("total_tokens")
  cost        Decimal?    @db.Decimal(10, 6)
  latencyMs   Int?        @map("latency_ms")
  errorMsg    String?     @map("error_msg")
  createdBy   String?     @map("created_by") @db.Uuid
  updatedBy   String?     @map("updated_by") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?   @map("deleted_at") @db.Timestamptz
  version     Int         @default(0)

  result AiResult?
  audit  AiAudit?

  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, feature, subjectId])
  @@map("ai_jobs")
}

model AiAudit {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  aiJobId         String   @unique @map("ai_job_id") @db.Uuid
  promptHash      String?  @map("prompt_hash")
  responseHash    String?  @map("response_hash")
  executionTimeMs Int?     @map("execution_time_ms")
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  job AiJob @relation(fields: [aiJobId], references: [id])

  @@index([tenantId, aiJobId])
  @@map("ai_audit")
}

model AiResult {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  aiJobId        String   @unique @map("ai_job_id") @db.Uuid
  summary        String?
  recommendation String?
  confidence     Decimal? @db.Decimal(5, 4)
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  job AiJob @relation(fields: [aiJobId], references: [id])

  @@index([tenantId, aiJobId])
  @@map("ai_results")
}

enum SecuritySeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SecurityStatus {
  SUCCESS
  DENIED
  PENDING
}

model SecurityLog {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String?          @map("user_id") @db.Uuid
  action         String
  status         SecurityStatus   @default(SUCCESS)
  severity       SecuritySeverity @default(INFO)
  ipAddress      String           @map("ip_address")
  geoLocation    String?          @map("geo_location")
  riskScore      Int              @default(0) @map("risk_score")
  metadata       Json?            @map("metadata")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([severity])
  @@index([createdAt])
  @@index([userId])
  @@index([tenantId, organizationId])
  @@map("security_logs")
}

model SecurityAlert {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  title          String
  description    String
  severity       SecuritySeverity @default(HIGH)
  status         String           @default("ACTIVE")
  ipAddress      String?          @map("ip_address")
  userId         String?          @map("user_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt     DateTime?        @map("resolved_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([severity])
  @@index([createdAt])
  @@index([userId])
  @@index([tenantId, organizationId])
  @@map("security_alerts")
}

enum ReportCategory {
  ATTENDANCE
  PAYROLL
  TIMESHEETS
  LABOR_COST
  COMPLIANCE
  DEPARTMENT_ANALYTICS
}

enum ReportStatus {
  PENDING
  COMPLETED
  FAILED
}

model GeneratedReport {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  name           String
  category       ReportCategory
  format         String         @default("PDF") // PDF, CSV, XLSX
  dateRange      String?        @map("date_range")
  status         ReportStatus   @default(PENDING)
  filePath       String?        @map("file_path")
  downloadCount  Int            @default(0) @map("download_count")
  createdBy      String         @map("created_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  creator User @relation(fields: [createdBy], references: [id])

  @@index([organizationId])
  @@index([category])
  @@index([createdAt])
  @@index([tenantId, organizationId])
  @@map("generated_reports")
}
