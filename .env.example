# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
# Most host platforms (Railway, Render, Fly.io) inject PORT automatically and
# expect the app to bind to it — that takes priority over API_PORT when set.
# Only set API_PORT explicitly for local/manual setups.
API_PORT=3000
# Set to the deployed frontend's exact origin in production (e.g.
# https://timeforge.vercel.app) — this also doubles as the base URL used to
# build password-reset and email-verification links sent to users.
CORS_ORIGINS=http://localhost:3001

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
# DEV default: owner role (tenant isolation enforced at the Prisma-middleware
# layer). For DB-level RLS, run `npm run db:rls` then switch DATABASE_URL to the
# restricted role: postgresql://timeforge_app:app_password@localhost:5432/timeforge
# (see README → Row-Level Security; requires per-request tenant GUC wiring).
DATABASE_URL=postgresql://timeforge_owner:owner_password@localhost:5432/timeforge?schema=public
# Privileged URL used for migrations / seeding / RLS setup (owner role).
DIRECT_URL=postgresql://timeforge_owner:owner_password@localhost:5432/timeforge?schema=public

# ─── Redis (cache + BullMQ) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────
# WARNING: Generate strong secrets for production: openssl rand -hex 64
JWT_ACCESS_SECRET=dev-access-secret-min-8-chars
JWT_REFRESH_SECRET=dev-refresh-secret-min-8-chars
JWT_ACCESS_TTL=900            # seconds (15m)
JWT_REFRESH_TTL=1209600       # seconds (14d)
ARGON2_MEMORY_COST=19456
# Required: "true" in production (HTTPS); "false" in dev (HTTP)
COOKIE_SECURE=false

# ─── AI provider (abstracted; default OpenAI) ─────────────────────────────
AI_PROVIDER=OPENAI
OPENAI_API_KEY=
OPENAI_MODEL=qwen/qwen3.6-plus   # qwen/qwen3.6-plus via OpenRouter (OpenAI-compatible)
OPENAI_BASE_URL=https://api.openai.com/v1  # override for Azure or proxy

# ─── Storage (local disk by default; Supabase Storage in prod) ────────────
STORAGE_DRIVER=local                 # local | supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=           # server-side only — never expose to the client
SUPABASE_STORAGE_BUCKET=timeforge

# ─── Using Supabase as the database? ──────────────────────────────────────
# Point the URLs at your Supabase project (Project Settings → Database):
#   DATABASE_URL = pooled connection (PgBouncer, port 6543, append &pgbouncer=true)
#   DIRECT_URL   = direct connection (port 5432) — used by Prisma migrations
# Example:
#   DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
#   DIRECT_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Rate limiting (defaults; see throttler config) ───────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ─── Public registration (single-tenant MVP: new signups join this tenant/org) ─
DEFAULT_TENANT_SLUG=demo
DEFAULT_ORG_SLUG=demo-org

# ─── Google SMTP (Nodemailer) ─────────────────────────────────────────────────
# Used to send registration, password reset & verification emails via Gmail.
# Steps to enable:
#   1. Go to https://myaccount.google.com/security and turn on 2-Step Verification.
#   2. Search for "App passwords" → create a new one (name it "TimeForge").
#   3. Copy the 16-character password and paste it below as SMTP_PASS.
#   4. Set SMTP_USER to your Gmail address.
# Leave SMTP_USER / SMTP_PASS empty to fall back to console-only (mock) logging.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587                           # 587 (TLS/STARTTLS) or 465 (SSL)
SMTP_USER=your-gmail@gmail.com          # Gmail address
SMTP_PASS=xxxx xxxx xxxx xxxx          # 16-char Gmail App Password (spaces optional)
SMTP_FROM=TimeForge Team <your-gmail@gmail.com>
