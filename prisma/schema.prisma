  userId         String          @map("user_id") @db.Uuid
  entryDate      DateTime        @map("entry_date") @db.Date
  yesterday      String
  /// Legacy JSON-encoded task list; superseded by the ScrumTask table. Kept for backward compatibility.
  today          String
  /// Legacy JSON-encoded blocker list; superseded by the ScrumBlocker table. Kept for backward compatibility.
  blockers       String?
  notes          String?
  /// Self-reported task progress for the day, 0–100.
  progress       Int             @default(0)
  status         ScrumTaskStatus @default(NOT_STARTED)
  /// True once progress reaches 100% — mirrors status === COMPLETED but persisted explicitly per spec.
  isLocked       Boolean         @default(false) @map("is_locked")
  submittedAt    DateTime?       @map("submitted_at") @db.Timestamptz
  projectId      String?         @map("project_id") @db.Uuid
  clientId       String?         @map("client_id") @db.Uuid
  kpi            String?
  plannedTarget  String?         @map("planned_target")
  supervisorNote String?         @map("supervisor_note")
  createdBy      String?         @map("created_by") @db.Uuid
  updatedBy      String?         @map("updated_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz
  version        Int             @default(0)

  organization Organization   @relation(fields: [tenantId, organizationId], references: [tenantId, id])
  user         User           @relation(fields: [userId], references: [id])
  project      Project?       @relation(fields: [projectId], references: [id])
  client       Client?        @relation(fields: [clientId], references: [id])
  tasks        ScrumTask[]
  blockerItems ScrumBlocker[]

  // Uniqueness enforced by a partial unique index (WHERE deleted_at IS NULL) —
  // see migration 20260710000000_soft_delete_partial_unique_indexes. The plain
  // index below (same columns) already covers query support.
  @@index([tenantId, organizationId, entryDate])
  @@index([tenantId, userId, entryDate])
  @@index([tenantId, organizationId, submittedAt])
  @@map("scrum_entries")
}

