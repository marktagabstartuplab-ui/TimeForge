// TimeForge — Prisma schema.
// Phase 6: Core Organization (Department, Team, Client, Project, WorkCategory, Holiday).
// Phase 7: Time Tracking (TimeEntry).
// Phase 8: Smart Timesheets (Timesheet).
// Phase 9: Daily Scrum, Supervisor Approval, KPI, Payroll Preparation.
// Every business table carries the standard columns: tenant_id, organization_id,
// created_by, updated_by, created_at, updated_at, deleted_at, version.
// RLS is applied via prisma/sql/rls.sql.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserStatus {
  PENDING
  INVITED
  ACTIVE
  SUSPENDED
  DEACTIVATED
  REJECTED
}

enum EmploymentType {
  EMPLOYEE
  INTERN
  CONTRACTOR
  PART_TIME
  FULL_TIME
}

enum ScrumTaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

// ─── Daily Scrum tasks/blockers & Session Tracking enums ────────────────────

/// Per-task status on a ScrumTask (distinct from ScrumEntry's day-level ScrumTaskStatus above).
enum ScrumTaskItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ScrumTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum BlockerSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BlockerStatus {
  OPEN
  RESOLVED
}

enum SessionEventType {
  CLOCK_IN
  BREAK_START
  BREAK_END
  TASK_COMPLETED
  CLOCK_OUT
}

enum AttachmentType {
  GITHUB
  FIGMA
  PR
  GOOGLE_DOCS
  OTHER_LINK
  FILE
}

enum AuditAction {
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  REVISION_REQUEST
  PAYROLL_EXPORT
  ROLE_CHANGE
  PASSWORD_CHANGE
  AI_USAGE
  SETTINGS_CHANGE
  ADMIN_ACTION
  PAYROLL_VALIDATED
  PAYROLL_APPROVED
  PAYROLL_REJECTED
  PAYROLL_SENT_TO_BANK
}

enum LeaveType {
  ANNUAL
  SICK
  PERSONAL
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum TimeEntrySource {
  TIMER
  MANUAL
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  REVISION_REQUESTED
  PAYROLL_READY
}

// Phase 9 enums ───────────────────────────────────────────────────────────────

enum ApprovalAction {
  APPROVE
  REJECT
  REQUEST_REVISION
}

enum KpiMetricType {
  COUNT
  HOURS
  PERCENT
  CURRENCY
  /// Free-form metric — Name/Unit/Formula/etc. live on KpiTemplate's custom-metric fields.
  CUSTOM
}

enum KpiPeriod {
  DAILY
  WEEKLY
  MONTHLY
  PAYROLL_PERIOD
}

enum PayrollPeriodType {
  FIRST_HALF
  SECOND_HALF
  CUSTOM
}

enum PayrollPeriodStatus {
  OPEN
  GENERATED
  LOCKED
  EXPORTED
}

enum PayrollProcessingStatus {
  DRAFT
  VALIDATING
  VALIDATED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SENT_TO_BANK
}

// ─── Tenancy & Core Organization ────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organizations Organization[]

  @@map("tenants")
}

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  slug      String
  timezone  String    @default("UTC")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  version   Int       @default(0)

  tenant          Tenant                @relation(fields: [tenantId], references: [id])
  settings        OrganizationSetting[]
  users           User[]
  departments     Department[]
  teams           Team[]
  clients         Client[]
  projects        Project[]
  workCategories  WorkCategory[]
  holidays        Holiday[]
  timeEntries     TimeEntry[]
  timesheets      Timesheet[]
  scrumEntries    ScrumEntry[]
  kpiTemplates    KpiTemplate[]
  payrollPeriods  PayrollPeriod[]
  shifts          Shift[]
  leaveRequests   LeaveRequest[]
  leaveBalances   LeaveBalance[]
  recurringIssues RecurringIssue[]

  @@unique([tenantId, id])
  // Uniqueness on (tenantId, slug) is enforced by a partial unique index
  // (WHERE deleted_at IS NULL) added in migration 20260710000000_soft_delete_partial_unique_indexes —
  // Prisma's schema DSL can't express a partial @@unique, so this is a plain
  // index for query support only; the DB constraint is the source of truth.
  @@index([tenantId, slug])
  @@index([tenantId])
  @@map("organizations")
}

model OrganizationSetting {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  key            String
  value          Json
  type           String    @default("json")
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  version        Int       @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])

  // Uniqueness enforced by a partial unique index (WHERE deleted_at IS NULL) —
  // see migration 20260710000000_soft_delete_partial_unique_indexes.
  @@index([tenantId, organizationId, key])
  @@map("organization_settings")
}

// ─── Users & RBAC ────────────────────────────────────────────────────────────

model User {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  organizationId  String         @map("organization_id") @db.Uuid
  email           String
  passwordHash    String?        @map("password_hash")
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  phone           String?        @map("phone")
  jobTitle        String?        @map("job_title")
  status          UserStatus     @default(PENDING)
  isApproved      Boolean        @default(false) @map("is_approved")
  // Role the user asked for at self-registration (EMPLOYEE | INTERN). It's a
  // request only — the admin assigns the real Role/UserRole on approval. Stored
  // for the approval UI + admin notification; not a security boundary.
  requestedRole   String?        @map("requested_role")
  employmentType  EmploymentType @default(EMPLOYEE) @map("employment_type")
  hourlyRate      Decimal?       @map("hourly_rate") @db.Decimal(12, 2)
  payrollEligible Boolean        @default(true) @map("payroll_eligible")
  avatarKey       String?        @map("avatar_key")
  lastLoginAt     DateTime?      @map("last_login_at") @db.Timestamptz
  emailVerifiedAt DateTime?      @map("email_verified_at") @db.Timestamptz
  rejectedAt      DateTime?      @map("rejected_at") @db.Timestamptz
  rejectionReason String?        @map("rejection_reason")
  supervisorId    String?        @map("supervisor_id") @db.Uuid
  departmentId    String?        @map("department_id") @db.Uuid
  teamId          String?        @map("team_id") @db.Uuid
  createdBy       String?        @map("created_by") @db.Uuid
  updatedBy       String?        @map("updated_by") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz
  version         Int            @default(0)

  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockoutUntil        DateTime? @map("lockout_until") @db.Timestamptz

  emailVerificationToken     String?   @map("email_verification_token")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at") @db.Timestamptz
  passwordResetToken         String?   @map("password_reset_token")
  passwordResetExpiresAt     DateTime? @map("password_reset_expires_at") @db.Timestamptz

  organization          Organization      @relation(fields: [tenantId, organizationId], references: [tenantId, id])
  department            Department?       @relation(fields: [departmentId], references: [id])
  team                  Team?             @relation(fields: [teamId], references: [id])
  roles                 UserRole[]
  refreshTokens         RefreshToken[]
  timeEntries           TimeEntry[]
  timesheets            Timesheet[]
  scrumEntries          ScrumEntry[]
  scrumTasks            ScrumTask[]
  workSessions          WorkSession[]
  kpiProgress           KpiProgress[]
  approvals             Approval[]        @relation("SupervisorApprovals")
  payrollLineItems      PayrollLineItem[]
  notifications         Notification[]
  sentNotifications     Notification[]    @relation("NotificationSender")
  departmentsManaged    Department[]      @relation("DepartmentManager")
  securityLogs          SecurityLog[]
  securityAlerts        SecurityAlert[]
  generatedReports      GeneratedReport[]
  shifts                Shift[]
  leaveRequests         LeaveRequest[]    @relation("LeaveRequestUser")
  leaveRequestsReviewed LeaveRequest[]    @relation("LeaveRequestReviewer")
  leaveBalances         LeaveBalance[]    @relation("LeaveBalanceUser")

  @@unique([tenantId, id])
  // Uniqueness on (tenantId, email) is enforced by a partial unique index
  // (WHERE deleted_at IS NULL) — see migration 20260710000000_soft_delete_partial_unique_indexes.
  @@index([tenantId, email])
  @@index([tenantId, organizationId])
  @@index([tenantId, teamId])
  @@index([tenantId, organizationId, supervisorId])
  @@index([tenantId, organizationId, status])
  @@index([tenantId, organizationId, departmentId])
  @@map("users")
}

model Role {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  key       String
  name      String
  isSystem  Boolean   @default(true) @map("is_system")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  version   Int       @default(0)

  permissions RolePermission[]
  users       UserRole[]

  // Uniqueness enforced by a partial unique index (WHERE deleted_at IS NULL) —
  // see migration 20260710000000_soft_delete_partial_unique_indexes.
  @@index([tenantId, key])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// ─── Auth sessions ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  familyId  String    @map("family_id") @db.Uuid
  device    String?
  ip        String?
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([tenantId, expiresAt])
  @@index([familyId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ─── Audit & idempotency ─────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  action     AuditAction
  entityType String?     @map("entity_type")
  entityId   String?     @map("entity_id") @db.Uuid
  metadata   Json?
  ip         String?
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, createdAt])
  @@index([tenantId, actorId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, entityType, action, createdAt(sort: Desc)])
  @@map("audit_log")
}

model IdempotencyKey {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  key       String
  endpoint  String?
  resultRef String?   @map("result_ref")
  expiresAt DateTime? @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tenantId, key])
  @@map("idempotency_keys")
}

// ─── Core Organization — Phase 6 ─────────────────────────────────────────────

model Department {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  managerId      String?   @map("manager_id") @db.Uuid
  isActive       Boolean   @default(true) @map("is_active")
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  version        Int       @default(0)

  organization    Organization     @relation(fields: [tenantId, organizationId], references: [tenantId, id])
  manager         User?            @relation("DepartmentManager", fields: [managerId], references: [id])
  users           User[]
  teams           Team[]
  projects        Project[]
  shifts          Shift[]
  timeEntries     TimeEntry[]
  recurringIssues RecurringIssue[]

  // Uniqueness enforced by a partial unique index (WHERE deleted_at IS NULL) —
  // see migration 20260710000000_soft_delete_partial_unique_indexes.
  @@index([tenantId, organizationId, name])
  @@map("departments")
}

model Team {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  departmentId   String?   @map("department_id") @db.Uuid
  supervisorId   String?   @map("supervisor_id") @db.Uuid
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  version        Int       @default(0)

  organization Organization @relation(fields: [tenantId, organizationId], references: [tenantId, id])
  department   Department?  @relation(fields: [departmentId], references: [id])
  users        User[]

  // Uniqueness enforced by a partial unique index (WHERE deleted_at IS NULL) —
  // see migration 20260710000000_soft_delete_partial_unique_indexes.
  @@index([tenantId, organizationId, name])
  @@map("teams")
}

model Client {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  contact        String?
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  version        Int       @default(0)

  organization Organization @relation(fields: [tenantId, organizationId], references: [tenantId, id])
  projects     Project[]
  timeEntries  TimeEntry[]
  scrumEntries ScrumEntry[]

  // Uniqueness enforced by a partial unique index (WHERE deleted_at IS NULL) —
  // see migration 20260710000000_soft_delete_partial_unique_indexes.
  @@index([tenantId, organizationId, name])
  @@map("clients")
}

enum ProjectStatus {
  ON_TRACK
  AT_RISK
  DELAYED
}

model Project {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  name           String
  code           String
  clientId       String?       @map("client_id") @db.Uuid
  departmentId   String?       @map("department_id") @db.Uuid
  status         ProjectStatus @default(ON_TRACK)
  billable       Boolean       @default(true)
  createdBy      String?       @map("created_by") @db.Uuid
  updatedBy      String?       @map("updated_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz
  version        Int           @default(0)

  organization    Organization     @relation(fields: [tenantId, organizationId], references: [tenantId, id])
  client          Client?          @relation(fields: [clientId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  timeEntries     TimeEntry[]
  scrumEntries    ScrumEntry[]
  scrumTasks      ScrumTask[]
  recurringIssues RecurringIssue[]

  // Uniqueness enforced by a partial unique index (WHERE deleted_at IS NULL) —
  // see migration 20260710000000_soft_delete_partial_unique_indexes.
  @@index([tenantId, organizationId, code])
  @@index([tenantId, organizationId, departmentId])
  @@map("projects")
}

model WorkCategory {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  version        Int       @default(0)

  organization Organization @relation(fields: [tenantId, organizationId], references: [tenantId, id])
  timeEntries  TimeEntry[]

  // Uniqueness enforced by a partial unique index (WHERE deleted_at IS NULL) —
  // see migration 20260710000000_soft_delete_partial_unique_indexes.
  @@index([tenantId, organizationId, name])
  @@map("work_categories")
}

model Holiday {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  date           DateTime  @db.Date
  recurring      Boolean   @default(false)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  version        Int       @default(0)

  organization Organization @relation(fields: [tenantId, organizationId], references: [tenantId, id])

  // Uniqueness enforced by a partial unique index (WHERE deleted_at IS NULL) —
  // see migration 20260710000000_soft_delete_partial_unique_indexes.
  @@index([tenantId, organizationId, date, name])
  @@map("holidays")
}

// ─── Time Tracking — Phase 7 ─────────────────────────────────────────────────

model TimeEntry {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  organizationId  String          @map("organization_id") @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  timesheetId     String?         @map("timesheet_id") @db.Uuid
  workSessionId   String?         @map("work_session_id") @db.Uuid
  projectId       String?         @map("project_id") @db.Uuid
  clientId        String?         @map("client_id") @db.Uuid
  workCategoryId  String?         @map("work_category_id") @db.Uuid
  source          TimeEntrySource @default(MANUAL)
  startTime       DateTime        @map("start_time") @db.Timestamptz
  endTime         DateTime?       @map("end_time") @db.Timestamptz
  durationMinutes Int?            @map("duration_minutes")
  task            String?
  description     String?
  deliverables    String?
  departmentId    String?         @map("department_id") @db.Uuid
  referenceLinks  Json?           @map("reference_links")
  attachments     Json?           @map("attachments")
  createdBy       String?         @map("created_by") @db.Uuid
  updatedBy       String?         @map("updated_by") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz
  version         Int             @default(0)

  organization Organization  @relation(fields: [tenantId, organizationId], references: [tenantId, id])
  user         User          @relation(fields: [userId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])
  project      Project?      @relation(fields: [projectId], references: [id])
  client       Client?       @relation(fields: [clientId], references: [id])
  workCategory WorkCategory? @relation(fields: [workCategoryId], references: [id])
  timesheet    Timesheet?    @relation(fields: [timesheetId], references: [id])
  workSession  WorkSession?  @relation(fields: [workSessionId], references: [id])

  @@index([tenantId, userId, startTime])
  @@index([tenantId, organizationId])
  @@index([tenantId, departmentId])
  @@index([tenantId, projectId])
  @@index([tenantId, clientId])
  @@index([timesheetId])
  @@index([workSessionId])
  @@map("time_entries")
}

// ─── Smart Timesheets — Phase 8 ──────────────────────────────────────────────

model Timesheet {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  status         TimesheetStatus @default(DRAFT)
  periodStart    DateTime        @map("period_start") @db.Date
  periodEnd      DateTime        @map("period_end") @db.Date
  totalMinutes   Int             @default(0) @map("total_minutes")
  summary        String?
  submittedAt    DateTime?       @map("submitted_at") @db.Timestamptz
  decidedAt      DateTime?       @map("decided_at") @db.Timestamptz
  createdBy      String?         @map("created_by") @db.Uuid
  updatedBy      String?         @map("updated_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz
