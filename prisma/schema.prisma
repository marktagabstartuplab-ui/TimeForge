// ─── Recurring Operational Issues (cross-employee/department/project) ──────
// Deterministic, rule-based detection over ScrumBlocker/ScrumTask records —
// runs alongside (not instead of) the AI BLOCKER_DETECTION toggle and the
// simple per-employee attachRecurringBlockerFlag() in scrum.service.ts.

enum RecurringIssueCategory {
  BLOCKER
  DELAY

  @@map("recurring_issue_category")
}

enum RecurringIssueTrend {
  INCREASING
  STABLE
  DECREASING

  @@map("recurring_issue_trend")
}

enum RecurringIssueStatus {
  OPEN
  RESOLVED

  @@map("recurring_issue_status")
}

model RecurringIssue {
  id              String                 @id @default(uuid()) @db.Uuid
  tenantId        String                 @map("tenant_id") @db.Uuid
  organizationId  String                 @map("organization_id") @db.Uuid
  category        RecurringIssueCategory
  issueText       String                 @map("issue_text")
  departmentId    String?                @map("department_id") @db.Uuid
  projectId       String?                @map("project_id") @db.Uuid
  /// Employees who reported/were affected by this recurring issue.
  employeeIds     String[]               @map("employee_ids") @db.Uuid
  occurrenceCount Int                    @default(1) @map("occurrence_count")
  firstOccurrence DateTime               @map("first_occurrence") @db.Timestamptz
  lastOccurrence  DateTime               @map("last_occurrence") @db.Timestamptz
  trend           RecurringIssueTrend    @default(STABLE)
  suggestedAction String?                @map("suggested_action")
  status          RecurringIssueStatus   @default(OPEN)
  resolvedAt      DateTime?              @map("resolved_at") @db.Timestamptz
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz
  version         Int                    @default(0)

  organization Organization @relation(fields: [tenantId, organizationId], references: [tenantId, id])
  department   Department?  @relation(fields: [departmentId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])

  @@index([tenantId, organizationId, status])
  @@index([tenantId, organizationId, departmentId])
  @@index([tenantId, organizationId, projectId])
  @@index([tenantId, organizationId, lastOccurrence])
  @@map("recurring_issues")
}

