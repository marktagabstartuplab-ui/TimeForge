# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
CORS_ORIGINS=http://localhost:3001

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
# DEV default: owner role (tenant isolation enforced at the Prisma-middleware
# layer). For DB-level RLS, run `npm run db:rls` then switch DATABASE_URL to the
# restricted role: postgresql://timeforge_app:app_password@localhost:5432/timeforge
# (see README → Row-Level Security; requires per-request tenant GUC wiring).
DATABASE_URL=postgresql://timeforge_owner:owner_password@localhost:5432/timeforge?schema=public
# Privileged URL used for migrations / seeding / RLS setup (owner role).
DIRECT_URL=postgresql://timeforge_owner:owner_password@localhost:5432/timeforge?schema=public

# ─── Redis (cache + BullMQ) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900            # seconds (15m)
JWT_REFRESH_TTL=1209600       # seconds (14d)
ARGON2_MEMORY_COST=19456
COOKIE_SECURE=false           # true in production (HTTPS)

# ─── AI provider (abstracted; default OpenAI) ─────────────────────────────
AI_PROVIDER=OPENAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini         # override to gpt-4o for higher quality
OPENAI_BASE_URL=https://api.openai.com/v1  # override for Azure or proxy

# ─── Storage (local disk by default; Supabase Storage in prod) ────────────
STORAGE_DRIVER=local                 # local | supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=           # server-side only — never expose to the client
SUPABASE_STORAGE_BUCKET=timeforge

# ─── Using Supabase as the database? ──────────────────────────────────────
# Point the URLs at your Supabase project (Project Settings → Database):
#   DATABASE_URL = pooled connection (PgBouncer, port 6543, append &pgbouncer=true)
#   DIRECT_URL   = direct connection (port 5432) — used by Prisma migrations
# Example:
#   DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
#   DIRECT_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Rate limiting (defaults; see throttler config) ───────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ─── Public registration (single-tenant MVP: new signups join this tenant/org) ─
DEFAULT_TENANT_SLUG=demo
DEFAULT_ORG_SLUG=demo-org
