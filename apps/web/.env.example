# Base URL of the deployed NestJS API (no trailing slash, no /api/v1 suffix —
# the client appends that itself). Must be a real, publicly reachable URL in
# production — the frontend cannot reach a localhost API once deployed.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Used only for Supabase Realtime (push notifications) — this app authenticates
# with its own JWTs, not Supabase Auth, so these are safe to expose client-side
# (anon key only, never the service role key). The app degrades to no
# real-time notifications if left unset; everything else still works.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
